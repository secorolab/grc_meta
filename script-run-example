#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage: script-run-example [--headless] <workspace-path>

Runs the default pick-place example:
  make run MODEL=pick_place_single FSM=pick_place_single.fsm

Options:
  --headless   Run without a GUI (make run-headless); needs no display.
               Honors STEPS=<n> from the environment.
USAGE
}

die() {
    printf 'Error: %s\n' "$*" >&2
    exit 1
}

HEADLESS=0
args=()
for a in "$@"; do
    case "$a" in
        --headless) HEADLESS=1 ;;
        -h|--help) usage; exit 0 ;;
        *) args+=("$a") ;;
    esac
done
set -- "${args[@]}"

if [ "$#" -ne 1 ]; then
    usage
    exit 2
fi

[ -d "$1" ] || die "workspace path does not exist: $1"
WS="$(cd -- "$1" && pwd -P)"
ENV_FILE="$WS/setup-grc.${SHELL##*/}"
MODELS_DIR="$WS/src/bdd_collab_bhv_cpp/models"

[ -r "$ENV_FILE" ] || die "missing $ENV_FILE; run script-setup first"
[ -d "$MODELS_DIR" ] || die "missing models directory: $MODELS_DIR"

target="run"
if [ "$HEADLESS" -eq 1 ]; then
    target="run-headless"
elif [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; then
    die "no GUI display detected; set DISPLAY/WAYLAND_DISPLAY, or pass --headless"
fi

# ROS 2 / colcon setup files reference unbound vars; source them with -u off.
set +u
source "$ENV_FILE"
set -u
cd "$MODELS_DIR"
exec make "$target" MODEL=pick_place_single FSM=pick_place_single.fsm
