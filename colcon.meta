            "cmake-args": [
                "-DENABLE_ETHERCAT=OFF",
                "-DENABLE_KELO=OFF",
                "-DENABLE_KORTEX=ON",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DENABLE_KORTEX_API_AUTO_DOWNLOAD=ON"
            ]
        },
        "mj_kdl_wrapper": {
            "cmake-args": [
                "-DBUILD_TESTS=ON",
                "-DMJ_KDL_FETCH_MENAGERIE=ON"
            ]
        }
    }
}
